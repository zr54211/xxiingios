&НаКлиенте
Перем Компонента;

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПодключитьНажатие(Команда)

	Записать("Подключение компоненты...");
	Оповещение = Новый ОписаниеОповещения("ПодключитьЗавершение", ЭтотОбъект);
	НачатьПодключениеВнешнейКомпоненты(Оповещение, "ОбщийМакет.BarcodeScannerZXing", "SCNR",
		ТипВнешнейКомпоненты.Native);

КонецПроцедуры

&НаКлиенте
Процедура ПоказатьНажатие(Команда)

	Если Компонента = Неопределено Тогда

		Записать("Сначала подключите компоненту");
		Возврат;

	КонецЕсли;

	// Непрерывный режим: экран не закрывается после распознавания (тест рамки).
	Компонента.НачатьСканирование("{""autoClose"":false}");
	Записать("НачатьСканирование выполнено (autoClose:false)");

КонецПроцедуры

&НаКлиенте
Процедура СкрытьНажатие(Команда)

	Если Компонента = Неопределено Тогда

		Записать("Сначала подключите компоненту");
		Возврат;

	КонецЕсли;

	Компонента.ЗавершитьСканирование();
	Записать("ЗавершитьСканирование выполнено");

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ВнешнееСобытие(Источник, Событие, Данные)

	Если Источник <> "BarcodeScannerZXing" Тогда
		Возврат;
	КонецЕсли;

	Если Событие = "ScanResult" Тогда

		// Экран сканера закрывается самой компонентой (autoClose по умолчанию).
		Записать("ScanResult: " + Данные);

	ИначеЕсли Событие = "ScanCancelled" Тогда

		Записать("Сканирование отменено пользователем");

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПодключитьЗавершение(Подключено, ДополнительныеПараметры) Экспорт

	Если НЕ Подключено Тогда

		Записать("ОШИБКА: компонента не подключилась");
		Возврат;

	КонецЕсли;

	Компонента = Новый ("AddIn.SCNR.BarcodeScannerZXing");
	Версия = Компонента.Версия;
	Записать("Подключено. Версия: " + Версия);

КонецПроцедуры

&НаКлиенте
Процедура Записать(Текст)

	Лог = Формат(ТекущаяДата(), "ДФ=HH:mm:ss") + " " + Текст + Символы.ПС + Лог;

КонецПроцедуры

#КонецОбласти
